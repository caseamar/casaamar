{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://casaamar.es/schemas/knowledge-entry.schema.json",
  "title": "Casa Amar Knowledge Entry",
  "type": "object",
  "required": [
    "id",
    "category",
    "title",
    "content",
    "visibility",
    "trust",
    "status",
    "source",
    "updated"
  ],
  "properties": {
    "id": {
      "type": "string",
      "pattern": "^[a-z0-9][a-z0-9-]+$"
    },
    "category": {
      "type": "string"
    },
    "title": {
      "type": "string"
    },
    "content_type": {
      "type": "string",
      "enum": [
        "fact",
        "guide",
        "note",
        "recommendation",
        "procedure",
        "faq"
      ]
    },
    "content": {
      "type": "string"
    },
    "keywords": {
      "type": "array",
      "items": {
        "type": "string"
      }
    },
    "visibility": {
      "type": "string",
      "enum": [
        "public",
        "internal",
        "guest_only"
      ]
    },
    "trust": {
      "type": "integer",
      "minimum": 0,
      "maximum": 100
    },
    "status": {
      "type": "string",
      "enum": [
        "draft",
        "review",
        "active",
        "deprecated",
        "archived"
      ]
    },
    "dynamic": {
      "type": "boolean"
    },
    "valid_from": {
      "type": [
        "string",
        "null"
      ],
      "format": "date"
    },
    "valid_until": {
      "type": [
        "string",
        "null"
      ],
      "format": "date"
    },
    "source": {
      "type": "object",
      "required": [
        "id",
        "type"
      ],
      "properties": {
        "id": {
          "type": "string"
        },
        "type": {
          "type": "string",
          "enum": [
            "owner_core",
            "owner_note",
            "website",
            "booking_agency",
            "official_web",
            "external_web"
          ]
        },
        "label": {
          "type": "string"
        },
        "url": {
          "type": [
            "string",
            "null"
          ]
        },
        "checked": {
          "type": [
            "string",
            "null"
          ],
          "format": "date"
        }
      }
    },
    "updated": {
      "type": "string",
      "format": "date"
    },
    "owner": {
      "type": "string"
    },
    "language": {
      "type": "string",
      "default": "da"
    },
    "links": {
      "type": "array",
      "items": {
        "type": "object",
        "required": [
          "label",
          "url"
        ],
        "properties": {
          "label": {
            "type": "string"
          },
          "url": {
            "type": "string"
          }
        }
      }
    }
  },
  "additionalProperties": true
}
